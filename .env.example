# Database (Neon Postgres)
DATABASE_URL=

# Dev server port (Next.js; keep in sync with NEXT_PUBLIC_APP_URL)
PORT=3000

# App URL (fallback for Stripe redirects when Host is localhost; include protocol).
# Production: use www — apex dentily.co 307-redirects to www.dentily.co at Vercel.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=https://www.dentily.co

# Auth (NextAuth / Auth.js v5)
AUTH_URL=http://localhost:3000
AUTH_SECRET=
# Legacy alias also supported: NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (test keys for local dev)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Dashboard → Webhooks → endpoint URL (must use www, not apex):
# https://www.dentily.co/api/webhooks/stripe

# Subscription price IDs (Stripe Dashboard → Products)
STRIPE_PRO_PRICE_ID=
STRIPE_STARTER_PRICE_ID=

# Optional: legacy external payment link (deprecated — use in-app checkout)
# NEXT_PUBLIC_STRIPE_MONTHLY_LINK=

# Google Places (New) — lead sourcing (Places API enabled in Google Cloud Console)
GOOGLE_MAPS_API_KEY=

# Hunter.io — email enrichment fallback (Domain Search). https://hunter.io/api-keys
# Free tier = 25 lookups/month; usage is capped per search.
HUNTER_API_KEY=
# DENTILY_HUNTER_MAX_LOOKUPS=25
# DENTILY_HUNTER_DELAY_MS=200
# DENTILY_DISABLE_HUNTER=1

# Multi-tier enrichment (lib/enrichEmail.ts). All optional — each tier is skipped
# when its key is absent. ZeroBounce verifies guessed addresses; Apollo + Prospeo
# (with the NPI registry) find provider emails.
ZEROBOUNCE_API_KEY=
APOLLO_API_KEY=
PROSPEO_API_KEY=

# Anthropic — AI outreach generator (/dashboard/outreach) + background CSV enrichment
ANTHROPIC_API_KEY=

# Resend — email enriched CSV after starter pack purchase
RESEND_API_KEY=
RESEND_FROM_EMAIL=Dentily <leads@dentily.co>

# Internal auth for POST /api/enrich-background (set in production)
ENRICH_BACKGROUND_SECRET=
