# Database (Neon Postgres)
DATABASE_URL=

# Dev server port (Next.js; keep in sync with NEXT_PUBLIC_APP_URL)
PORT=3000

# App URL (fallback for Stripe redirects when Host is localhost; include protocol).
# On Vercel production, set this to your canonical domain (e.g. https://dentily.co).
# Do NOT use a one-off *.vercel.app preview URL — those expire and cause DEPLOYMENT_NOT_FOUND after Stripe.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (test keys for local dev)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Payment Link for Dentily Monthly ($39/mo). Create in Stripe → Product → Payment Link.
# NEXT_PUBLIC_STRIPE_MONTHLY_LINK=https://buy.stripe.com/xxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_MONTHLY_LINK=
